          "http": {
            "method": "PUT",
            "url": "https://securitylake.{region}.amazonaws.com/v1/subscribers/:subscriberId",
            "params": [
              {
                "name": "subscriberId",
                "value": "",
                "type": "path",
                "description": "The ID of the subscriber to update."
