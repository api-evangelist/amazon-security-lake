        {
          "info": {
            "name": "Amazon Security Lake Delete Subscriber",
            "type": "http"
          },
          "http": {
            "method": "DELETE",
            "url": "https://securitylake.{region}.amazonaws.com/v1/subscribers/:subscriberId",
